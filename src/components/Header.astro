---
import { url } from '../data/site';

const nav = [
  { label: 'About', href: url('/') },
  { label: 'Projects', href: url('/projects') },
  { label: 'Reads', href: url('/reads') },
  { label: 'Resume', href: url('/resume') },
];

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
const homeHref = url('/').replace(/\/$/, '') || '/';
const isCurrent = (href: string) => {
  const base = href.replace(/\/$/, '') || '/';
  if (base === homeHref) return current === base;
  return current === base || current.startsWith(`${base}/`);
};
---

<header data-print-hide>
  <div class="inner">
    <nav aria-label="Main">
      {nav.map((item, i) => (
        <div class="item">
          {i > 0 && <span class="divider" aria-hidden="true"></span>}
          <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
            {item.label}
          </a>
        </div>
      ))}
    </nav>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: var(--bg);
  }

  .inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 22px clamp(22px, 6vw, 40px);
    display: flex;
    justify-content: flex-end;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 13px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .item {
    display: flex;
    align-items: center;
    gap: 13px;
  }

  .divider {
    display: block;
    width: 1px;
    height: 10px;
    background: var(--rule);
  }

  nav a {
    white-space: nowrap;
    padding-bottom: 3px;
    color: var(--muted);
    border-bottom: 1px solid transparent;
    transition: color 0.2s ease;
  }

  nav a[aria-current='page'] {
    color: var(--accent);
    border-bottom: 1px solid var(--accent);
  }
</style>
