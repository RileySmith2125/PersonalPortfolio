---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';

interface Props {
  read: CollectionEntry<'reads'>;
}

const { read } = Astro.props;
const { title, author, type, dateRead, rating } = read.data;
const { Content } = await render(read);

const stars = rating ? '★'.repeat(rating) + '☆'.repeat(5 - rating) : null;
---

<article class="row">
  <div class="head">
    <span class="title">{title}</span>
    <span class="year">{dateRead.getUTCFullYear()}</span>
  </div>
  <div class="meta">
    {author} · {type}
    {stars && <span class="stars" aria-label={`Rated ${rating} out of 5`}> {stars}</span>}
  </div>
  <div class="note">
    <Content />
  </div>
</article>

<style>
  .row {
    padding: 24px 0;
    border-top: 1px solid var(--rule);
  }

  .head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 18px;
  }

  .title {
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .year {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
    white-space: nowrap;
    letter-spacing: 0.08em;
  }

  .meta {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 9px;
  }

  .stars {
    margin-left: 9px;
    letter-spacing: 0.18em;
    color: var(--accent);
  }

  .note {
    font-size: 12.5px;
    color: var(--muted);
    line-height: 1.85;
    margin-top: 12px;
  }

  .note :global(p) {
    margin: 0;
  }
</style>
