---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<span class="tag">{label}</span>

<style>
  .tag {
    display: inline-block;
    background: var(--accent-soft);
    color: var(--accent);
    border-radius: 999px;
    padding: 0.15rem 0.65rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }
</style>
