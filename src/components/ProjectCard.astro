---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { url } from '../data/site';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, image } = project.data;
---

<a class="card" href={url(`/projects/${project.id}`)}>
  <div class="thumb">
    {image ? (
      <Image src={image} alt={title} width={640} />
    ) : (
      <span class="chip">{title}</span>
    )}
  </div>
  <div class="title">{title}</div>
  <p class="desc">{description}</p>
</a>

<style>
  .card {
    display: block;
    cursor: pointer;
    padding: 12px;
    margin: -12px;
    transition: background 0.16s ease;
  }

  .card:hover {
    background: var(--faint);
  }

  .thumb {
    position: relative;
    aspect-ratio: 4 / 3;
    border: 1px solid var(--rule);
    background-color: var(--bg);
    background-image: repeating-linear-gradient(
      135deg,
      var(--faint) 0,
      var(--faint) 1px,
      transparent 1px,
      transparent 11px
    );
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .chip {
    font-family: var(--font-mono);
    font-size: 8.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    background: var(--bg);
    padding: 5px 9px;
    border: 1px solid var(--rule);
  }

  .title {
    font-size: 17px;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin-top: 15px;
  }

  .desc {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.5;
    margin-top: 5px;
  }
</style>
