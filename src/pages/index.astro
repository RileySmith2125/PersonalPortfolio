---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout>
  <div class="about">
    <h1>{site.name}</h1>
    <p class="bio">{site.bio}</p>
  </div>
</BaseLayout>

<style>
  .about {
    min-height: calc(100vh - 68px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 48px clamp(24px, 6vw, 40px) 96px;
  }

  h1 {
    font-size: clamp(32px, 6.4vw, 74px);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.05;
    white-space: nowrap;
  }

  .bio {
    font-size: 14.5px;
    line-height: 2;
    color: var(--muted);
    max-width: 48ch;
    margin-top: 32px;
  }
</style>
