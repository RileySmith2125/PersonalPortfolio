---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../data/site';
import { formatProjectDate } from '../../utils/formatProjectDate';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, role, startDate, endDate, tags, repoUrl, demoUrl, bullets, caption } =
  project.data;
const { Content } = await render(project);

const metaLine = [role, formatProjectDate(startDate, endDate), tags.join(' · ')]
  .filter(Boolean)
  .join(' · ');
---

<BaseLayout title={title} description={description}>
  <div class="detail">
    <a class="back" href={url('/projects')}>← Projects</a>
    <h1>{title}</h1>
    <div class="meta">{metaLine}</div>
    {(repoUrl || demoUrl) && (
      <div class="links">
        {repoUrl && (
          <a href={repoUrl} target="_blank" rel="noopener noreferrer">Source ↗</a>
        )}
        {demoUrl && (
          <a href={demoUrl} target="_blank" rel="noopener noreferrer">Live demo ↗</a>
        )}
      </div>
    )}

    <div class="overview">
      <Content />
    </div>

    {bullets.length > 0 && (
      <ul class="bullets">
        {bullets.map((b) => <li>{b}</li>)}
      </ul>
    )}

    <div class="figure-wrap">
      <div class="figure">
        <span class="chip">[ {caption || title} ]</span>
      </div>
      <div class="drop-label">Drop a screenshot here</div>
    </div>
  </div>
</BaseLayout>

<style>
  .detail {
    max-width: 640px;
    margin: 0 auto;
    padding: clamp(52px, 9vh, 104px) clamp(24px, 6vw, 40px) 120px;
  }

  .back {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    cursor: pointer;
  }

  h1 {
    font-size: clamp(30px, 4.6vw, 48px);
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 20px 0 14px;
  }

  .meta {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    line-height: 1.9;
  }

  .links {
    display: flex;
    gap: 22px;
    margin-top: 18px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .links a {
    border-bottom: 1px solid var(--accent);
    padding-bottom: 3px;
    color: var(--accent);
  }

  .overview {
    margin-top: clamp(36px, 6vh, 60px);
  }

  .overview :global(p) {
    font-size: 14px;
    line-height: 2;
    margin: 0 0 22px;
  }

  .bullets {
    list-style: none;
    padding: 0;
    margin: 18px 0 0;
    border-top: 1px solid var(--rule);
  }

  .bullets li {
    font-size: 12.5px;
    color: var(--muted);
    line-height: 1.65;
    padding: 13px 0 13px 22px;
    border-bottom: 1px solid var(--rule);
    position: relative;
  }

  .bullets li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .figure-wrap {
    margin-top: clamp(36px, 6vh, 60px);
  }

  .figure {
    position: relative;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--rule);
    background-color: var(--bg);
    background-image: repeating-linear-gradient(
      135deg,
      var(--faint) 0,
      var(--faint) 1px,
      transparent 1px,
      transparent 11px
    );
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .figure .chip {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    background: var(--bg);
    padding: 7px 12px;
    border: 1px solid var(--rule);
  }

  .drop-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 12px;
  }
</style>
