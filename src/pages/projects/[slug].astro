---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Tag from '../../components/Tag.astro';
import { url } from '../../data/site';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, startDate, endDate, tags, repoUrl, demoUrl, image } =
  project.data;
const { Content } = await render(project);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---

<BaseLayout title={title} description={description}>
  <a class="back muted" href={url('/projects')}>← All projects</a>
  <article>
    <h1>{title}</h1>
    <p class="meta muted">
      {fmt(startDate)} – {endDate ? fmt(endDate) : 'Present'}
    </p>
    {tags.length > 0 && (
      <div class="tags">
        {tags.map((tag) => <Tag label={tag} />)}
      </div>
    )}
    <div class="links">
      {repoUrl && (
        <a href={repoUrl} target="_blank" rel="noopener noreferrer">View source ↗</a>
      )}
      {demoUrl && (
        <a href={demoUrl} target="_blank" rel="noopener noreferrer">Live demo ↗</a>
      )}
    </div>
    {image && <Image src={image} alt={title} width={1024} class="hero-img" />}
    <div class="body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .back {
    font-size: var(--text-sm);
    display: inline-block;
    margin-bottom: var(--space-4);
  }

  .meta {
    font-size: var(--text-sm);
    margin-top: calc(-1 * var(--space-2));
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .links {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    font-weight: 550;
    font-size: var(--text-sm);
  }

  .hero-img {
    margin-bottom: var(--space-4);
  }

  .body {
    line-height: 1.7;
  }
</style>
