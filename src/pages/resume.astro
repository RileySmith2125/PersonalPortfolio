---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResumeContent from '../components/ResumeContent.astro';
import { site } from '../data/site';
---

<BaseLayout title="Resume" description={`${site.name}'s résumé.`}>
  <div class="resume-shell">
    <div class="resume-toolbar" data-print-hide>
      <span class="label">Resume · letter · print to PDF</span>
      <button id="save-resume-btn">Save résumé</button>
    </div>
    <div class="resume-paper">
      <ResumeContent />
    </div>
  </div>
</BaseLayout>

<script>
  document.getElementById('save-resume-btn')?.addEventListener('click', () => window.print());
</script>
